{% extends "layouts.master" %}

{% block content %}
<section class="page-shell">
  <div class="container">
    <div class="page-card split">
      <div>
        <div class="notice">صفحة منتج مصممة للوضوح والتحويل السريع.</div>
        <h1>{{ product.name|default('اسم المنتج') }}</h1>
        <p class="small-note">{{ product.description|default('ضع هنا وصفًا مختصرًا يشرح ماذا سيستلم العميل ومتى.') }}</p>
        <div style="margin:18px 0 10px">
          <span class="price">{{ product.price|default('—') }}</span>
        </div>
        <ul class="features" style="margin-top:18px">
          <li>تسليم فوري بعد الدفع</li>
          <li>وصف مختصر بدون تشتيت</li>
          <li>زر شراء واضح</li>
        </ul>
        <div style="display:flex; gap:12px; flex-wrap:wrap; margin-top:22px;">
          <button class="btn btn-primary">أضف إلى السلة</button>
          <a class="btn btn-secondary" href="/cart">اذهب إلى السلة</a>
        </div>
      </div>
      <div class="placeholder-box">صورة المنتج / معرض الصور</div>
    </div>
  </div>
</section>
{% endblock %}
